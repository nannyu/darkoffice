{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "lib": ["ES2019", "DOM"],
    "types": ["miniprogram-api-typings"],
    "declaration": false,
    "sourceMap": false,
    "removeComments": true,
    "outDir": "./miniprogram",
    "rootDir": "./miniprogram"
  },
  "include": [
    "miniprogram/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "cloudfunctions"
  ]
}
