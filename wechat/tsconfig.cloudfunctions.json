{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "lib": ["ES2019"],
    "types": ["node"],
    "declaration": false,
    "sourceMap": false,
    "removeComments": true
  },
  "include": [
    "cloudfunctions/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
